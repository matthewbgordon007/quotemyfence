# Google Maps - for address autocomplete & map search (required for best experience)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SITE_URL=https://quotemyfence.ca

# Resend (optional – for contractor + customer emails on submit)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=quotes@yourdomain.com

# Stripe Billing (required for subscription/trial gating)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
