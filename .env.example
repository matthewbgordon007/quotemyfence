# Google Maps - for address autocomplete & map search (required for best experience)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (optional – for contractor + customer emails on submit)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=quotes@yourdomain.com

# Template catalog: slug of contractor whose product catalog is the default for new signups.
# New contractors get the same types, styles, and colours with blank pricing (they set their own).
TEMPLATE_CONTRACTOR_SLUG=gordon-landscaping
